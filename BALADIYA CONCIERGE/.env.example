# ============================================================
# Baladiya Concierge — .env.example
# Copy to .env and fill in values. Never commit .env.
# .env holds ONLY Vault root token + ports — all other secrets come from Vault.
# ============================================================

# --- HashiCorp Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token          # root token for local dev / CI only

# --- Ports (override defaults if needed) ---
API_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
VAULT_PORT=8200
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MODELSERVER_PORT=8001
GUARDRAILS_PORT=8002

# --- Service tokens (seeded into Vault by migrate; also set on guardrails container) ---
# Generate a real random token for production: openssl rand -hex 32
GUARDRAILS_SERVICE_TOKEN=dev-guardrails-token

# --- Seed accounts (read by the migrate container at first boot) ---
PLATFORM_MANAGER_EMAIL=platform@baladiya.local
PLATFORM_MANAGER_PASSWORD=changeme

TENANT_A_NAME="Municipality A"
TENANT_A_ADMIN_EMAIL=admin-a@baladiya.local
TENANT_A_ADMIN_PASSWORD=changeme

TENANT_B_NAME="Municipality B"
TENANT_B_ADMIN_EMAIL=admin-b@baladiya.local
TENANT_B_ADMIN_PASSWORD=changeme
